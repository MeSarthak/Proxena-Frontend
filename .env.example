VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Backend URL
# In development: leave this unset (or set to http://localhost:3000) — Vite's dev proxy handles it.
# In production: MUST include the https:// scheme, e.g. https://your-backend.azurewebsites.net
# Do NOT omit the protocol — without it, all API and WebSocket calls will break in production.
VITE_API_BASE_URL=https://your-backend.azurewebsites.net
